{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"slug": "section-soft",
	"title": "Section: Soft",
	"blockTypes": [ "core/group", "core/columns" ],
	"styles": {
		"color": {
			"background": "var:preset|color|primary-50",
			"text": "var:preset|color|neutral-800"
		},
		"border": {
			"radius": "var:custom|radius|large"
		},
		"spacing": {
			"padding": {
				"top": "var:preset|spacing|lg",
				"bottom": "var:preset|spacing|lg",
				"left": "var:preset|spacing|md",
				"right": "var:preset|spacing|md"
			}
		},
		"elements": {
			"heading": { "color": { "text": "var:preset|color|primary-900" } }
		}
	}
}
